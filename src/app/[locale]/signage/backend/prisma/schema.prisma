// src/app/[locale]/signage/backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // Assumes DATABASE_URL is set in the environment
}

//---------------------------------------------------------------------
// Device Models
//---------------------------------------------------------------------

enum DeviceStatus {
  PENDING_PAIRING // Initial state when code is generated, before device pairs
  UNPAIRED        // State if pairing fails or device is reset (not actively used by current logic but good to have)
  ONLINE          // Device is paired and has recently communicated
  OFFLINE         // Device is paired but has not communicated recently
  ERROR           // Device has reported an error state
}

model Device {
  id                   String  @id @default(uuid()) @db.Uuid
  name                 String?
  status               DeviceStatus @default(PENDING_PAIRING)
  pairingCode          String? @unique // The raw code, not hyphenated
  pairingCodeExpiresAt DateTime?

  currentPlaylistId String?   @db.Uuid
  currentPlaylist   Playlist? @relation("DeviceToPlaylist", fields: [currentPlaylistId], references: [id], onDelete: SetNull)

  lastSeenAt       DateTime?
  ipAddress        String?
  macAddress       String?
  firmwareVersion  String?
  deviceSpecificConfig Json? // For any other config specific to this device

  organizationId String // Assuming organization is a concept managed elsewhere, not a direct relation here yet
                       // If Organization is a Prisma model:
                       // organization   Organization @relation(fields: [organizationId], references: [id])
                       // organizationId String @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
}

//---------------------------------------------------------------------
// Media Models
//---------------------------------------------------------------------

enum MediaType {
  VIDEO
  IMAGE
  AUDIO
  URL    // For web content, etc.
  WIDGET // For more complex embedded content
}

model Media {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    // Original filename or user-defined name
  type      MediaType
  mimeType  String?   // e.g., "video/mp4", "image/jpeg"
  url       String    // URL to the media file (e.g., CDN link)
  thumbnailUrl String? // URL to a thumbnail for the media

  sizeBytes       Int?
  durationSeconds Int?    // For time-based media (video, audio)
  width           Int?    // For visual media (image, video)
  height          Int?    // For visual media (image, video)
  metadata        Json?   // For EXIF, video encoding details, etc.

  // Assuming User is a concept managed elsewhere
  // If User is a Prisma model:
  // uploadedByUser User   @relation(fields: [uploadedByUserId], references: [id])
  uploadedByUserId String // @db.Uuid if User model exists with Uuid id

  organizationId String // @db.Uuid if Organization model exists
                       // organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  contentHash String? // <<<< ADD THIS LINE

  playlistItems PlaylistItem[] // Media can be in many playlist items

  @@index([organizationId])
  @@index([type])
  @@index([uploadedByUserId])
}

//---------------------------------------------------------------------
// Playlist Models
//---------------------------------------------------------------------

model Playlist {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String?

  // Assuming User is a concept managed elsewhere
  // If User is a Prisma model:
  // createdByUser User   @relation(fields: [createdByUserId], references: [id])
  createdByUserId String // @db.Uuid if User model exists

  organizationId String // @db.Uuid if Organization model exists
                       // organization   Organization @relation(fields: [organizationId], references: [id])

  items PlaylistItem[] @relation("PlaylistToItems") // Ordered items in the playlist

  assignedDevices Device[] @relation("DeviceToPlaylist") // Devices this playlist is assigned to
  scheduledEvents ScheduledEvent[] // Playlists can be scheduled multiple times

  version Int @default(1)
  contentUpdatedAt DateTime? // Manually managed by resolvers on item changes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([createdByUserId])
}

model PlaylistItem {
  id        String @id @default(uuid()) @db.Uuid
  order     Int    // 0-indexed order within the playlist
  durationSeconds Int  // How long this specific item should play in this playlist

  settings Json? // Item-specific settings: transitions, volume, fit (contain/cover), etc.
                 // Example: { "transitionFromPrevious": { "type": "FADE", "duration": 1 }, "volume": 80 }

  playlist   Playlist @relation("PlaylistToItems", fields: [playlistId], references: [id], onDelete: Cascade)
  playlistId String   @db.Uuid

  media    Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade) // Cascade delete if media is deleted? Or Restrict?
  mediaId  String @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // Note: Prisma does not auto-update this on relation changes by default.
                                // Application logic might need to touch `updatedAt` on the Playlist.

  @@unique([playlistId, order]) // Ensures order is unique within a playlist
  @@index([playlistId])
  @@index([mediaId])
}

