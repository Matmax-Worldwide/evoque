//---------------------------------------------------------------------
// Scheduling Models
//---------------------------------------------------------------------

enum TargetType {
  DEVICE
  DEVICE_GROUP // Conceptual, actual DeviceGroup model not defined in this schema yet
}

model ScheduledEvent {
  id        String   @id @default(uuid()) @db.Uuid
  title     String?  // Optional user-defined title for the schedule entry
  startTime DateTime // Start time of the first occurrence or the single event
  endTime   DateTime // End time of the first occurrence or the single event
  allDay    Boolean  @default(false) // If the event is an all-day event

  // Recurrence Information
  // Uses iCalendar RRULE string format (https://icalendar.org/iCalendar-RFC-5545/3-8-5-3-recurrence-rule.html)
  // Example: "FREQ=WEEKLY;BYDAY=MO,WE,FR;UNTIL=20241231T235959Z"
  // Parsing and generating these RRULEs will be handled by application logic (likely using a library).
  rrule          String?  // Recurrence rule string
  timezone       String?  // Timezone for the event, e.g., "America/New_York". Important for recurrence.

  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade) // What content to play
  playlistId String   @db.Uuid

  // Targeting: For simplicity, storing arrays of IDs.
  // A more normalized approach might use a separate EventTarget junction table,
  // especially if targets can have specific roles or settings per event.
  targetDeviceIds    String[] @db.Uuid // Array of Device IDs
  // For conceptual device groups. If DeviceGroup becomes a real model, this could be a relation.
  targetDeviceGroupIds String[] // Array of conceptual Device Group IDs

  // Denormalized names for easier display in some contexts, updated by application logic
  // These are optional and primarily for read optimization if needed.
  // Not strictly necessary if relations are always followed.
  // playlistName String?
  // targetNames  String[]

  // Who created/owns this schedule
  organizationId String   // Matches organizationId on Playlist and Device
  // createdByUserId String // Matches userId on Playlist

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // exceptions RecurrenceException[] // This relation is on the RecurrenceException side, not directly here.
  // The back-relation in Playlist for RecurrenceException (if one were needed) would be:
  // overriddenInExceptions RecurrenceException[] @relation("ExceptionToPlaylist")

  @@index([playlistId])
  @@index([organizationId])
  @@index([startTime]) // For querying by date range
  @@index([endTime])
}

model RecurrenceException {
  id        String   @id @default(uuid()) @db.Uuid
  event     ScheduledEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   String   @db.Uuid

  originalInstanceDate DateTime // The specific occurrence date of the recurring event that this exception applies to.
                                 // This should be the original start time of the instance being overridden.

  // If isCancelled is true, this instance is simply skipped.
  isCancelled Boolean @default(false)

  // If not cancelled, these fields can override the original instance's properties.
  // If null, the original instance's property is used.
  newStartTime DateTime?
  newEndTime   DateTime?
  newPlaylistId String? @db.Uuid
  newPlaylist   Playlist? @relation("ExceptionToPlaylist", fields: [newPlaylistId], references: [id], onDelete:SetNull)

  // Potentially new targets for this specific instance, if overriding is needed
  // newTargetDeviceIds    String[] @db.Uuid
  // newTargetDeviceGroupIds String[]

  // newTitle String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, originalInstanceDate]) // An event can only have one exception for a given original date.
  @@index([eventId])
  @@index([newPlaylistId])
}

